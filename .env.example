# Neon Postgres connection string (HTTP driver).
# Create a free database at https://neon.tech and paste its connection string here.
# Copy this file to .env.local before running the app.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth.js (NextAuth) secret — generate one with: npx auth secret
AUTH_SECRET="your-generated-secret"

# Google OAuth credentials.
# Create an OAuth client at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI (dev): http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
